# =============================================================================
# Sophia SEO Suite — environment template
# Copy to `.env` and fill values. NEVER commit a real `.env`.
# All secrets are read from env at runtime; nothing is hardcoded in source.
# =============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
# Random 32+ char string. Used to sign sessions. Generate, do not reuse.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Database (PostgreSQL) ---------------------------------------------------
# Matches docker-compose.yml defaults for local dev.
DATABASE_URL=postgresql://seo:seo@localhost:5432/sophia_seo?schema=public

# --- Redis / BullMQ (job queue) ----------------------------------------------
REDIS_URL=redis://localhost:6379

# --- AI provider (for content/draft generation; Tier 2+) ---------------------
# Provider-agnostic. Leave blank to disable AI features. Never log these.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Optional alternate provider slots (kept generic, opt-in):
OPENAI_API_KEY=
INCEPTION_API_KEY=

# --- Sophia Stack connector --------------------------------------------------
# Base URL of the target Sophia Stack site/server the connector talks to.
# For local mock connector this is ignored.
SOPHIA_STACK_BASE_URL=http://localhost:4000
# Bearer token issued by the Sophia Stack site (owner/admin scope).
# Connector uses this for authenticated read/patch/deploy calls.
SOPHIA_STACK_API_TOKEN=

# --- Crawler -----------------------------------------------------------------
# Politeness controls. Keep conservative — never scrape aggressively.
CRAWLER_USER_AGENT=SophiaSEOSuite/0.1 (+https://sophiaxt.com)
CRAWLER_MAX_CONCURRENCY=2
CRAWLER_REQUEST_DELAY_MS=1000
CRAWLER_RESPECT_ROBOTS=true

# --- Connector secret encryption ---------------------------------------------
# 32-byte base64 key used to encrypt stored connector credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONNECTOR_ENCRYPTION_KEY=
